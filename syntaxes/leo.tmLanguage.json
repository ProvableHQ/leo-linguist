{
  "name": "leo",
  "scopeName": "source.leo",
  "fileTypes": [
    "leo"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#program_declaration"
    },
    {
      "include": "#import_declaration"
    },
    {
      "include": "#function_declaration"
    },
    {
      "include": "#type_declaration"
    },
    {
      "include": "#address_literal"
    },
    {
      "include": "#suffix_literal"
    },
    {
      "include": "#numeric_literal"
    },
    {
      "include": "#string_literal"
    },
    {
      "include": "#identifier_literal"
    },
    {
      "include": "#language_constants"
    },
    {
      "include": "#language_variables"
    },
    {
      "include": "#assertions"
    },
    {
      "include": "#declaration_keywords"
    },
    {
      "include": "#modifier_keywords"
    },
    {
      "include": "#control_keywords"
    },
    {
      "include": "#special_types"
    },
    {
      "include": "#primitive_types"
    },
    {
      "include": "#program_id"
    },
    {
      "include": "#function_call"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.leo",
          "match": "//.*$"
        },
        {
          "name": "comment.block.leo",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "annotations": {
      "comment": "Attribute annotations like @program, @test, @noupgrade. The name may be a keyword.",
      "match": "(@)\\s*([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "punctuation.definition.annotation.leo"
        },
        "2": {
          "name": "entity.name.decorator.leo"
        }
      }
    },
    "program_declaration": {
      "comment": "program foo.aleo { ... }",
      "match": "\\b(program)\\s+([A-Za-z][A-Za-z0-9_]*)\\s*(\\.)\\s*(aleo)\\b",
      "captures": {
        "1": {
          "name": "keyword.other.program.leo"
        },
        "2": {
          "name": "entity.name.namespace.leo"
        },
        "3": {
          "name": "punctuation.accessor.leo"
        },
        "4": {
          "name": "keyword.other.network.leo"
        }
      }
    },
    "import_declaration": {
      "comment": "import foo.aleo;",
      "match": "\\b(import)\\s+([A-Za-z][A-Za-z0-9_]*)\\s*(\\.)\\s*(aleo)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.import.leo"
        },
        "2": {
          "name": "entity.name.namespace.leo"
        },
        "3": {
          "name": "punctuation.accessor.leo"
        },
        "4": {
          "name": "keyword.other.network.leo"
        }
      }
    },
    "function_declaration": {
      "comment": "Function name after fn (plain, final fn, view fn all reach `fn <name>`).",
      "match": "\\b(fn)\\s+([A-Za-z][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "storage.type.function.leo"
        },
        "2": {
          "name": "entity.name.function.leo"
        }
      }
    },
    "type_declaration": {
      "comment": "Type name after struct / record / interface.",
      "match": "\\b(struct|record|interface)\\s+([A-Za-z][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "storage.type.leo"
        },
        "2": {
          "name": "entity.name.type.leo"
        }
      }
    },
    "address_literal": {
      "comment": "aleo1... address literals. Must precede the `aleo` keyword and identifiers.",
      "name": "constant.other.address.leo",
      "match": "\\baleo1[a-z0-9]+\\b"
    },
    "suffix_literal": {
      "comment": "field / group / scalar literals; accept decimal and 0x/0o/0b bases.",
      "name": "constant.numeric.leo",
      "match": "\\b(0x[0-9a-fA-F_]+|0o[0-7_]+|0b[01_]+|[0-9][0-9_]*)(field|group|scalar)\\b"
    },
    "numeric_literal": {
      "comment": "Integer literals with optional type suffix and 0x/0o/0b bases.",
      "name": "constant.numeric.leo",
      "match": "\\b(0x[0-9a-fA-F_]+|0o[0-7_]+|0b[01_]+|[0-9][0-9_]*)(u8|u16|u32|u64|u128|i8|i16|i32|i64|i128)?\\b"
    },
    "string_literal": {
      "name": "string.quoted.double.leo",
      "begin": "\"",
      "end": "\""
    },
    "identifier_literal": {
      "comment": "Single-quoted identifier literals such as 'aleo', used as intrinsic arguments.",
      "name": "string.quoted.single.leo",
      "match": "'[A-Za-z][A-Za-z0-9_]*'"
    },
    "language_constants": {
      "name": "constant.language.leo",
      "match": "(?<!\\.)\\b(true|false|none)\\b"
    },
    "language_variables": {
      "name": "variable.language.leo",
      "match": "(?<!\\.)\\b(self|block|network)\\b"
    },
    "assertions": {
      "name": "support.function.builtin.leo",
      "match": "(?<!\\.)\\b(assert_eq|assert_neq|assert)\\b"
    },
    "declaration_keywords": {
      "name": "storage.type.leo",
      "match": "(?<!\\.)\\b(fn|struct|record|interface|mapping|storage|const|let|constructor)\\b"
    },
    "modifier_keywords": {
      "name": "storage.modifier.leo",
      "match": "(?<!\\.)\\b(export|final|view|public|private|constant|dyn)\\b"
    },
    "control_keywords": {
      "patterns": [
        {
          "name": "keyword.control.leo",
          "match": "(?<!\\.)\\b(if|else|for|in|return)\\b"
        },
        {
          "name": "keyword.operator.cast.leo",
          "match": "(?<!\\.)\\b(as)\\b"
        }
      ]
    },
    "special_types": {
      "comment": "Capitalized type keywords: Final, Fn, Future.",
      "name": "support.type.leo",
      "match": "(?<!\\.)\\b(Final|Fn|Future)\\b"
    },
    "primitive_types": {
      "name": "support.type.leo",
      "match": "(?<!\\.)\\b(address|bool|field|group|scalar|signature|string|identifier|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128)\\b"
    },
    "program_id": {
      "comment": "A bare program id `name.aleo` in locators and program references.",
      "match": "\\b([A-Za-z][A-Za-z0-9_]*)\\s*(\\.)\\s*(aleo)\\b",
      "captures": {
        "1": {
          "name": "entity.name.namespace.leo"
        },
        "2": {
          "name": "punctuation.accessor.leo"
        },
        "3": {
          "name": "keyword.other.network.leo"
        }
      }
    },
    "function_call": {
      "comment": "An identifier immediately followed by `(` is a call target.",
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": {
          "name": "entity.name.function.call.leo"
        }
      }
    },
    "operators": {
      "name": "keyword.operator.leo",
      "match": "->|=>|::|\\.\\.=?|\\*\\*=?|<<=?|>>=?|&&=?|\\|\\|=?|==|!=|<=|>=|[+\\-*/%&|^]=?|[<>!?=]"
    }
  }
}
