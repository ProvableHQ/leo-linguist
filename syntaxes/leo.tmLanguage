<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>name</key>
    <string>leo</string>
    <key>scopeName</key>
    <string>source.leo</string>
    <key>fileTypes</key>
    <array>
      <string>leo</string>
    </array>
    <key>patterns</key>
    <array>
      <dict>
        <key>include</key>
        <string>#comments</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#annotations</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#program_declaration</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#import_declaration</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#function_declaration</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#type_declaration</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#address_literal</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#suffix_literal</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#numeric_literal</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#string_literal</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#identifier_literal</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#language_constants</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#language_variables</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#assertions</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#declaration_keywords</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#modifier_keywords</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#control_keywords</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#special_types</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#primitive_types</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#program_id</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#function_call</string>
      </dict>
      <dict>
        <key>include</key>
        <string>#operators</string>
      </dict>
    </array>
    <key>repository</key>
    <dict>
      <key>comments</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>name</key>
            <string>comment.line.double-slash.leo</string>
            <key>match</key>
            <string>//.*$</string>
          </dict>
          <dict>
            <key>name</key>
            <string>comment.block.leo</string>
            <key>begin</key>
            <string>/\*</string>
            <key>end</key>
            <string>\*/</string>
          </dict>
        </array>
      </dict>
      <key>annotations</key>
      <dict>
        <key>comment</key>
        <string>Attribute annotations like @program, @test, @noupgrade. The name may be a keyword.</string>
        <key>match</key>
        <string>(@)\s*([A-Za-z_][A-Za-z0-9_]*)</string>
        <key>captures</key>
        <dict>
          <key>1</key>
          <dict>
            <key>name</key>
            <string>punctuation.definition.annotation.leo</string>
          </dict>
          <key>2</key>
          <dict>
            <key>name</key>
            <string>entity.name.decorator.leo</string>
          </dict>
        </dict>
      </dict>
      <key>program_declaration</key>
      <dict>
        <key>comment</key>
        <string>program foo.aleo { ... }</string>
        <key>match</key>
        <string>\b(program)\s+([A-Za-z][A-Za-z0-9_]*)\s*(\.)\s*(aleo)\b</string>
        <key>captures</key>
        <dict>
          <key>1</key>
          <dict>
            <key>name</key>
            <string>keyword.other.program.leo</string>
          </dict>
          <key>2</key>
          <dict>
            <key>name</key>
            <string>entity.name.namespace.leo</string>
          </dict>
          <key>3</key>
          <dict>
            <key>name</key>
            <string>punctuation.accessor.leo</string>
          </dict>
          <key>4</key>
          <dict>
            <key>name</key>
            <string>keyword.other.network.leo</string>
          </dict>
        </dict>
      </dict>
      <key>import_declaration</key>
      <dict>
        <key>comment</key>
        <string>import foo.aleo;</string>
        <key>match</key>
        <string>\b(import)\s+([A-Za-z][A-Za-z0-9_]*)\s*(\.)\s*(aleo)\b</string>
        <key>captures</key>
        <dict>
          <key>1</key>
          <dict>
            <key>name</key>
            <string>keyword.control.import.leo</string>
          </dict>
          <key>2</key>
          <dict>
            <key>name</key>
            <string>entity.name.namespace.leo</string>
          </dict>
          <key>3</key>
          <dict>
            <key>name</key>
            <string>punctuation.accessor.leo</string>
          </dict>
          <key>4</key>
          <dict>
            <key>name</key>
            <string>keyword.other.network.leo</string>
          </dict>
        </dict>
      </dict>
      <key>function_declaration</key>
      <dict>
        <key>comment</key>
        <string>Function name after fn (plain, final fn, view fn all reach `fn &lt;name&gt;`).</string>
        <key>match</key>
        <string>\b(fn)\s+([A-Za-z][A-Za-z0-9_]*)</string>
        <key>captures</key>
        <dict>
          <key>1</key>
          <dict>
            <key>name</key>
            <string>storage.type.function.leo</string>
          </dict>
          <key>2</key>
          <dict>
            <key>name</key>
            <string>entity.name.function.leo</string>
          </dict>
        </dict>
      </dict>
      <key>type_declaration</key>
      <dict>
        <key>comment</key>
        <string>Type name after struct / record / interface.</string>
        <key>match</key>
        <string>\b(struct|record|interface)\s+([A-Za-z][A-Za-z0-9_]*)</string>
        <key>captures</key>
        <dict>
          <key>1</key>
          <dict>
            <key>name</key>
            <string>storage.type.leo</string>
          </dict>
          <key>2</key>
          <dict>
            <key>name</key>
            <string>entity.name.type.leo</string>
          </dict>
        </dict>
      </dict>
      <key>address_literal</key>
      <dict>
        <key>comment</key>
        <string>aleo1... address literals. Must precede the `aleo` keyword and identifiers.</string>
        <key>name</key>
        <string>constant.other.address.leo</string>
        <key>match</key>
        <string>\baleo1[a-z0-9]+\b</string>
      </dict>
      <key>suffix_literal</key>
      <dict>
        <key>comment</key>
        <string>field / group / scalar literals; accept decimal and 0x/0o/0b bases.</string>
        <key>name</key>
        <string>constant.numeric.leo</string>
        <key>match</key>
        <string>\b(0x[0-9a-fA-F_]+|0o[0-7_]+|0b[01_]+|[0-9][0-9_]*)(field|group|scalar)\b</string>
      </dict>
      <key>numeric_literal</key>
      <dict>
        <key>comment</key>
        <string>Integer literals with optional type suffix and 0x/0o/0b bases.</string>
        <key>name</key>
        <string>constant.numeric.leo</string>
        <key>match</key>
        <string>\b(0x[0-9a-fA-F_]+|0o[0-7_]+|0b[01_]+|[0-9][0-9_]*)(u8|u16|u32|u64|u128|i8|i16|i32|i64|i128)?\b</string>
      </dict>
      <key>string_literal</key>
      <dict>
        <key>name</key>
        <string>string.quoted.double.leo</string>
        <key>begin</key>
        <string>"</string>
        <key>end</key>
        <string>"</string>
      </dict>
      <key>identifier_literal</key>
      <dict>
        <key>comment</key>
        <string>Single-quoted identifier literals such as 'aleo', used as intrinsic arguments.</string>
        <key>name</key>
        <string>string.quoted.single.leo</string>
        <key>match</key>
        <string>'[A-Za-z][A-Za-z0-9_]*'</string>
      </dict>
      <key>language_constants</key>
      <dict>
        <key>name</key>
        <string>constant.language.leo</string>
        <key>match</key>
        <string>(?&lt;!\.)\b(true|false|none)\b</string>
      </dict>
      <key>language_variables</key>
      <dict>
        <key>name</key>
        <string>variable.language.leo</string>
        <key>match</key>
        <string>(?&lt;!\.)\b(self|block|network)\b</string>
      </dict>
      <key>assertions</key>
      <dict>
        <key>name</key>
        <string>support.function.builtin.leo</string>
        <key>match</key>
        <string>(?&lt;!\.)\b(assert_eq|assert_neq|assert)\b</string>
      </dict>
      <key>declaration_keywords</key>
      <dict>
        <key>name</key>
        <string>storage.type.leo</string>
        <key>match</key>
        <string>(?&lt;!\.)\b(fn|struct|record|interface|mapping|storage|const|let|constructor)\b</string>
      </dict>
      <key>modifier_keywords</key>
      <dict>
        <key>name</key>
        <string>storage.modifier.leo</string>
        <key>match</key>
        <string>(?&lt;!\.)\b(export|final|view|public|private|constant|dyn)\b</string>
      </dict>
      <key>control_keywords</key>
      <dict>
        <key>patterns</key>
        <array>
          <dict>
            <key>name</key>
            <string>keyword.control.leo</string>
            <key>match</key>
            <string>(?&lt;!\.)\b(if|else|for|in|return)\b</string>
          </dict>
          <dict>
            <key>name</key>
            <string>keyword.operator.cast.leo</string>
            <key>match</key>
            <string>(?&lt;!\.)\b(as)\b</string>
          </dict>
        </array>
      </dict>
      <key>special_types</key>
      <dict>
        <key>comment</key>
        <string>Capitalized type keywords: Final, Fn, Future.</string>
        <key>name</key>
        <string>support.type.leo</string>
        <key>match</key>
        <string>(?&lt;!\.)\b(Final|Fn|Future)\b</string>
      </dict>
      <key>primitive_types</key>
      <dict>
        <key>name</key>
        <string>support.type.leo</string>
        <key>match</key>
        <string>(?&lt;!\.)\b(address|bool|field|group|scalar|signature|string|identifier|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128)\b</string>
      </dict>
      <key>program_id</key>
      <dict>
        <key>comment</key>
        <string>A bare program id `name.aleo` in locators and program references.</string>
        <key>match</key>
        <string>\b([A-Za-z][A-Za-z0-9_]*)\s*(\.)\s*(aleo)\b</string>
        <key>captures</key>
        <dict>
          <key>1</key>
          <dict>
            <key>name</key>
            <string>entity.name.namespace.leo</string>
          </dict>
          <key>2</key>
          <dict>
            <key>name</key>
            <string>punctuation.accessor.leo</string>
          </dict>
          <key>3</key>
          <dict>
            <key>name</key>
            <string>keyword.other.network.leo</string>
          </dict>
        </dict>
      </dict>
      <key>function_call</key>
      <dict>
        <key>comment</key>
        <string>An identifier immediately followed by `(` is a call target.</string>
        <key>match</key>
        <string>\b([A-Za-z_][A-Za-z0-9_]*)\s*(?=\()</string>
        <key>captures</key>
        <dict>
          <key>1</key>
          <dict>
            <key>name</key>
            <string>entity.name.function.call.leo</string>
          </dict>
        </dict>
      </dict>
      <key>operators</key>
      <dict>
        <key>name</key>
        <string>keyword.operator.leo</string>
        <key>match</key>
        <string>-&gt;|=&gt;|::|\.\.=?|\*\*=?|&lt;&lt;=?|&gt;&gt;=?|&amp;&amp;=?|\|\|=?|==|!=|&lt;=|&gt;=|[+\-*/%&amp;|^]=?|[&lt;&gt;!?=]</string>
      </dict>
    </dict>
  </dict>
</plist>